COGNEE_API_KEY=your_api_key_here

# Cognee Cloud Configuration (Set to enable Cognee Cloud SaaS mode & qualify for hackathon bounty)
COGNEE_SERVICE_URL=https://api.cognee.ai

# LLM Configuration
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-flash-latest
LLM_API_KEY=your_llm_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Embedding Configuration
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Multi-user access control
ENABLE_BACKEND_ACCESS_CONTROL=true

# Caching
CACHING=true
CACHE_BACKEND=fs

# Session
AUTO_FEEDBACK=true
SESSION_TTL_SECONDS=604800

# Security
ALLOW_CYPHER_QUERY=false
TELEMETRY_DISABLED=true

# Logging
LOG_LEVEL=INFO

# Server
PORT=8000
HOST=0.0.0.0
ENV=development

# Directories (will be created automatically)
SYSTEM_ROOT_DIRECTORY=./.cognee_system
DATA_ROOT_DIRECTORY=./.data_storage
